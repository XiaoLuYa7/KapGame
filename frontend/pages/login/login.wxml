<!--pages/login/login.wxml-->
<view class="container">
  <view class="card">
    <view class="header">
      <text style="font-size: 40rpx; font-weight: bold;">
        {{isLogin ? '登录' : '注册'}}
      </text>
    </view>

    <input
      class="input"
      placeholder="用户名"
      value="{{username}}"
      bindinput="onUsernameInput"
    />

    <input
      class="input"
      placeholder="密码"
      password
      value="{{password}}"
      bindinput="onPasswordInput"
    />

    <button class="btn" bindtap="submit">
      {{isLogin ? '登录' : '注册'}}
    </button>

    <view style="text-align: center; margin-top: 40rpx;">
      <text style="color: #666;">
        {{isLogin ? '没有账号？' : '已有账号？'}}
      </text>
      <text
        style="color: #2c3e50; margin-left: 20rpx;"
        bindtap="toggleMode"
      >
        {{isLogin ? '去注册' : '去登录'}}
      </text>
    </view>
  </view>
</view>