/* ============================================
   KapGame 对战主页样式
   设计风格：柔和玻璃 (Soft Glass)
   支持系统级白天/黑夜模式自动切换
   ============================================ */

/* ---------- 页面容器 ---------- */
.home-container {
  min-height: 100vh;
  background: transparent;
  padding: var(--space-lg);
  padding-bottom: 120rpx;
  box-sizing: border-box;
  position: relative;
}

/* ---------- 用户卡片区域 ---------- */
.home-header {
  margin-bottom: var(--space-xl);
}

/* ---------- 区域标题 ---------- */
.section-title {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--space-md) 0;
  margin-bottom: var(--space-md);
  position: relative;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 36rpx;
  background: linear-gradient(180deg, var(--accent-primary), var(--accent-secondary));
  border-radius: 3rpx;
}

.title-text {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-left: var(--space-lg);
}

.title-more {
  font-size: 26rpx;
  color: var(--text-muted);
  margin-right: var(--space-sm);
}

/* ---------- 活动滚动区域 ---------- */
.activities-scroll {
  width: 100%;
  white-space: nowrap;
}

.activities-list {
  display: inline-flex;
  gap: var(--space-lg);
  padding: var(--space-xs) 0;
}

.activity-item {
  display: inline-flex;
  flex-direction: column;
  width: 280rpx;
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--glass-border);
  overflow: hidden;
  transition: all 0.2s ease;
}

.activity-item:active {
  transform: scale(0.97);
}

.activity-image-wrapper {
  position: relative;
  width: 100%;
  height: 160rpx;
  overflow: hidden;
}

.activity-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.activity-image-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, var(--accent-primary) 0%, var(--accent-secondary) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.activity-default-icon {
  font-size: 64rpx;
}

.countdown-badge {
  position: absolute;
  top: var(--space-sm);
  right: var(--space-sm);
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(8px);
  border-radius: var(--radius-sm);
  padding: 6rpx var(--space-sm);
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.countdown-icon {
  font-size: 22rpx;
}

.countdown-text {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.activity-info {
  padding: var(--space-md);
}

.activity-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: var(--space-xs);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.activity-type-tag {
  display: inline-block;
  padding: 4rpx var(--space-sm);
  background: rgba(var(--accent-primary-rgb), 0.1);
  border-radius: var(--radius-sm);
}

.type-text {
  font-size: 22rpx;
  color: var(--accent-primary);
  font-weight: 500;
}

/* ---------- 空活动状态 ---------- */
.empty-activities {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-2xl);
}

.empty-text {
  font-size: 28rpx;
  color: var(--text-muted);
}

/* ---------- 游戏模式区域 ---------- */
.game-modes {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
  margin-bottom: var(--space-xl);
}

.game-mode-item {
  display: flex;
  align-items: center;
  padding: var(--space-lg);
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--glass-border);
  box-shadow: var(--shadow-card);
  transition: all 0.2s ease;
}

.game-mode-item:active {
  transform: scale(0.98);
  border-color: var(--accent-primary);
}

.game-mode-icon {
  width: 88rpx;
  height: 88rpx;
  background: linear-gradient(135deg, var(--accent-primary), var(--accent-secondary));
  border-radius: var(--radius-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.game-mode-icon text {
  font-size: 44rpx;
}

.game-mode-content {
  flex: 1;
  margin-left: var(--space-lg);
  min-width: 0;
}

.game-mode-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 4rpx;
}

.game-mode-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.game-mode-arrow {
  font-size: 40rpx;
  color: var(--text-muted);
  margin-left: var(--space-md);
  flex-shrink: 0;
}

/* ---------- 功能区域 ---------- */
.function-grid {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-md);
  margin-bottom: var(--space-xl);
}

.function-item {
  width: calc(50% - var(--space-sm));
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--space-xl) var(--space-md);
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border-radius: var(--radius-lg);
  border: 1rpx solid var(--glass-border);
  box-shadow: var(--shadow-card);
  transition: all 0.2s ease;
  box-sizing: border-box;
}

.function-item:active {
  transform: scale(0.97);
  border-color: var(--accent-primary);
}

.function-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, rgba(var(--accent-primary-rgb), 0.15), rgba(var(--accent-primary-rgb), 0.05));
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: var(--space-md);
}

.function-icon text {
  font-size: 40rpx;
}

.function-title {
  font-size: 26rpx;
  font-weight: 500;
  color: var(--text-primary);
  text-align: center;
}

/* ---------- 底部提示 ---------- */
.footer-tip {
  text-align: center;
  padding: var(--space-xl) 0;
}

.footer-tip text {
  font-size: 24rpx;
  color: var(--text-dim);
}
