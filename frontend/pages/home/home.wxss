/* ============================================
   KapGame 对战主页样式
   设计风格：柔和玻璃 (Soft Glass)
   支持系统级白天/黑夜模式自动切换
   ============================================ */

/* ---------- 页面容器 ---------- */
.home-container {
  min-height: 100vh;
  background: var(--bg-base);
  padding: var(--space-lg);
  box-sizing: border-box;
}

/* ---------- 顶部用户信息卡片 ---------- */
.home-header {
  display: flex;
  align-items: center;
  padding: var(--space-lg);
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-card);
  margin-bottom: var(--space-xl);
}

.home-header-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--accent-primary) 0%, var(--accent-dim) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 600;
  overflow: hidden;
  flex-shrink: 0;
  box-shadow: var(--shadow-accent);
}

.home-header-avatar image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.home-header-info {
  flex: 1;
  margin-left: var(--space-lg);
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.home-header-nickname {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-bright);
}

.home-header-level {
  font-size: 24rpx;
  color: var(--accent-primary);
  font-weight: 500;
}

/* ---------- 对战区域 ---------- */
.battle-section {
  margin-bottom: var(--space-xl);
}

.battle-card {
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-xl);
  padding: var(--space-2xl);
  box-shadow: var(--shadow-card);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-lg);
}

.battle-card-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-bright);
  text-align: center;
}

.battle-card-subtitle {
  font-size: 26rpx;
  color: var(--text-secondary);
  text-align: center;
  margin-top: calc(var(--space-sm) * -1);
}

/* 匹配按钮 */
.match-btn {
  width: 100%;
  padding: var(--space-lg) var(--space-xl);
  background: linear-gradient(135deg, var(--accent-primary) 0%, var(--accent-dim) 100%);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-accent);
  cursor: pointer;
  transition: all var(--transition-fast);
  -webkit-tap-highlight-color: transparent;
}

.match-btn:hover {
  background: linear-gradient(135deg, var(--accent-bright) 0%, var(--accent-primary) 100%);
  box-shadow: var(--shadow-elevated);
}

.match-btn:active {
  transform: scale(0.96);
}

.match-btn::after {
  border: none;
}

/* ---------- 快速对战区域 ---------- */
.quick-battle {
  margin-bottom: var(--space-xl);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-bright);
  margin-bottom: var(--space-lg);
  padding-left: var(--space-sm);
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.section-title::before {
  content: '';
  width: 6rpx;
  height: 32rpx;
  background: linear-gradient(180deg, var(--accent-primary), var(--accent-bright));
  border-radius: 3rpx;
}

.battle-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.battle-item {
  display: flex;
  align-items: center;
  padding: var(--space-lg);
  background: var(--bg-card);
  border: 1rpx solid var(--border-default);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-card);
  transition: all var(--transition-fast);
  min-height: 120rpx;
  box-sizing: border-box;
}

.battle-item:hover {
  background: var(--bg-hover);
  border-color: var(--border-bright);
  box-shadow: var(--shadow-elevated);
}

.battle-item:active {
  background: var(--bg-elevated);
  transform: scale(0.99);
}

.battle-item + .battle-item {
  margin-top: var(--space-sm);
}

.battle-icon {
  width: 88rpx;
  height: 88rpx;
  border-radius: var(--radius-lg);
  background: linear-gradient(135deg, var(--accent-primary) 0%, var(--accent-dim) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #FFFFFF;
  flex-shrink: 0;
  box-shadow: var(--shadow-accent);
}

.battle-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: var(--space-xs);
  margin-left: var(--space-lg);
}

.battle-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-bright);
}

.battle-desc {
  font-size: 24rpx;
  color: var(--text-secondary);
  line-height: 1.4;
}

.battle-arrow {
  color: var(--text-muted);
  font-size: 28rpx;
  margin-left: var(--space-md);
  transition: transform var(--transition-fast);
}

.battle-item:hover .battle-arrow {
  transform: translateX(4rpx);
  color: var(--accent-primary);
}
