<!-- pages/chat/chat.wxml -->
<view class="chat-container">
  <!-- 背景图片 -->
  <image class="page-bg" src="images/bg.png" mode="aspectFill" />

  <!-- Tab切换 -->
  <view class="tabs">
    <view
      class="tab-item {{currentTab === 'messages' ? 'active' : ''}}"
      data-tab="messages"
      bindtap="switchTab"
    >
      消息
      <view class="tab-indicator"></view>
    </view>
    <view
      class="tab-item {{currentTab === 'friends' ? 'active' : ''}}"
      data-tab="friends"
      bindtap="switchTab"
    >
      好友
      <view class="tab-indicator"></view>
    </view>
  </view>

  <!-- 消息列表 -->
  <view class="tab-content" wx:if="{{currentTab === 'messages'}}">
    <scroll-view class="messages-list" scroll-y="true">
      <view wx:for="{{messages}}" wx:key="id" class="message-item" data-id="{{item.id}}" bindtap="onMessageTap">
        <view class="message-avatar">
          <image src="{{item.avatar}}" mode="aspectFill"></image>
          <view class="message-badge" wx:if="{{item.unread > 0}}">{{item.unread}}</view>
        </view>
        <view class="message-content">
          <view class="message-header">
            <view class="message-name">{{item.name}}</view>
            <view class="message-time">{{item.time}}</view>
          </view>
          <view class="message-preview">{{item.content}}</view>
        </view>
        <view class="message-arrow">›</view>
      </view>
    </scroll-view>
  </view>

  <!-- 好友列表 -->
  <view class="tab-content" wx:if="{{currentTab === 'friends'}}">
    <!-- 搜索框 -->
    <view class="search-box">
      <view class="search-input-wrapper">
        <text class="search-icon">🔍</text>
        <input
          class="search-input"
          placeholder="搜索好友"
          value="{{searchKeyword}}"
          bindinput="onSearchInput"
        />
        <text class="search-clear" wx:if="{{searchKeyword}}" bindtap="clearSearch">×</text>
      </view>
      <view class="search-add-btn" bindtap="onAddFriend">
        <text class="add-icon">+</text>
      </view>
    </view>

    <!-- 好友列表 -->
    <scroll-view class="friends-list" scroll-y="true">
      <view wx:for="{{filteredFriends}}" wx:key="id" class="friend-item" data-id="{{item.id}}" bindtap="onFriendTap">
        <view class="friend-avatar">
          <image src="{{item.avatar}}" mode="aspectFill"></image>
          <view class="friend-status {{item.status}}"></view>
        </view>
        <view class="friend-info">
          <view class="friend-header">
            <view class="friend-name">{{item.name}}</view>
            <view class="friend-rank">{{item.rank}}</view>
          </view>
          <view class="friend-footer">
            <view class="friend-status-text {{item.status}}">
              {{item.status === 'online' ? '在线' : '离线'}}
            </view>
            <view class="friend-last-online">{{item.lastOnline}}</view>
          </view>
        </view>
        <view class="friend-action">
          <view class="chat-btn">聊天</view>
        </view>
      </view>

      <!-- 空状态 -->
      <view class="empty-state" wx:if="{{filteredFriends.length === 0}}">
        <text class="empty-icon">👥</text>
        <text class="empty-text">未找到好友</text>
      </view>
    </scroll-view>
  </view>

  <!-- 刷新按钮 -->
  <view class="refresh-btn" bindtap="onRefresh">
    <text class="refresh-icon">🔄</text>
    <text class="refresh-text">刷新</text>
  </view>
</view>