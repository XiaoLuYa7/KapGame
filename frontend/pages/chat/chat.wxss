/* pages/chat/chat.wxss */
.chat-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f5f7fa 0%, #e4e8f0 100%);
  padding: 0 30rpx 40rpx;
  box-sizing: border-box;
  padding-top: 20rpx;
}

/* Tab切换 */
.tabs {
  display: flex;
  background: white;
  border-radius: 16rpx;
  margin-bottom: 30rpx;
  padding: 8rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 32rpx;
  color: #7f8c8d;
  position: relative;
  transition: all 0.3s;
}

.tab-item.active {
  color: #3498db;
  font-weight: bold;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 6rpx;
  background: #3498db;
  border-radius: 3rpx;
  opacity: 0;
  transition: all 0.3s;
}

.tab-item.active .tab-indicator {
  opacity: 1;
}

/* 消息列表 */
.messages-list {
  height: calc(100vh - 300rpx);
}

.message-item {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.2s;
}

.message-item:active {
  transform: scale(0.98);
}

.message-avatar {
  position: relative;
  margin-right: 24rpx;
}

.message-avatar image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
}

.message-badge {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  background: #e74c3c;
  color: white;
  font-size: 22rpx;
  min-width: 36rpx;
  height: 36rpx;
  border-radius: 18rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-weight: bold;
}

.message-content {
  flex: 1;
}

.message-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.message-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #2c3e50;
}

.message-time {
  font-size: 26rpx;
  color: #95a5a6;
}

.message-preview {
  font-size: 28rpx;
  color: #7f8c8d;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}

.message-arrow {
  font-size: 50rpx;
  color: #bdc3c7;
  font-weight: bold;
  margin-left: 20rpx;
}

/* 好友列表 */
.search-box {
  display: flex;
  align-items: center;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.search-input-wrapper {
  flex: 1;
  position: relative;
  background: white;
  border-radius: 40rpx;
  padding: 0 30rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.search-icon {
  font-size: 36rpx;
  color: #95a5a6;
  margin-right: 16rpx;
}

.search-input {
  flex: 1;
  height: 100%;
  font-size: 30rpx;
  color: #2c3e50;
}

.search-clear {
  font-size: 40rpx;
  color: #95a5a6;
  padding: 10rpx;
}

.search-add-btn {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(52, 152, 219, 0.3);
  transition: transform 0.2s;
}

.search-add-btn:active {
  transform: scale(0.95);
}

.add-icon {
  color: white;
  font-size: 40rpx;
  font-weight: bold;
}

/* 好友列表 */
.friends-list {
  height: calc(100vh - 400rpx);
}

.friend-item {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
  transition: transform 0.2s;
}

.friend-item:active {
  transform: scale(0.98);
}

.friend-avatar {
  position: relative;
  margin-right: 24rpx;
}

.friend-avatar image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: #f0f0f0;
}

.friend-status {
  position: absolute;
  bottom: 0;
  right: 0;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  border: 4rpx solid white;
}

.friend-status.online {
  background-color: #2ecc71;
}

.friend-status.offline {
  background-color: #95a5a6;
}

.friend-info {
  flex: 1;
}

.friend-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.friend-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #2c3e50;
}

.friend-rank {
  font-size: 26rpx;
  color: #f39c12;
  font-weight: bold;
  background: #fef9e7;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.friend-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.friend-status-text {
  font-size: 26rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  font-weight: bold;
}

.friend-status-text.online {
  color: #27ae60;
  background: #e8f8f5;
}

.friend-status-text.offline {
  color: #7f8c8d;
  background: #f8f9fa;
}

.friend-last-online {
  font-size: 26rpx;
  color: #95a5a6;
}

.friend-action {
  margin-left: 20rpx;
}

.chat-btn {
  background: linear-gradient(135deg, #3498db 0%, #2980b9 100%);
  color: white;
  font-size: 26rpx;
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 10rpx rgba(52, 152, 219, 0.3);
  transition: transform 0.2s;
}

.chat-btn:active {
  transform: scale(0.95);
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 100rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-text {
  font-size: 32rpx;
  color: #95a5a6;
}

/* 刷新按钮 */
.refresh-btn {
  position: fixed;
  right: 40rpx;
  bottom: 40rpx;
  background: linear-gradient(135deg, #2c3e50 0%, #34495e 100%);
  color: white;
  padding: 20rpx 30rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 8rpx 30rpx rgba(44, 62, 80, 0.3);
  transition: transform 0.2s;
}

.refresh-btn:active {
  transform: scale(0.95);
}

.refresh-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

.refresh-text {
  font-size: 28rpx;
  font-weight: bold;
}