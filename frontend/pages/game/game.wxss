/* pages/game/game.wxss */
.player-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  margin: 10rpx 0;
  background-color: white;
  border-radius: 10rpx;
  border-left: 8rpx solid #3498db;
}

.hand-card {
  display: inline-block;
  width: 150rpx;
  height: 200rpx;
  background-color: #3498db;
  color: white;
  border-radius: 15rpx;
  margin: 10rpx;
  text-align: center;
  line-height: 200rpx;
  font-size: 32rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 8rpx rgba(0,0,0,0.1);
}

.hand-card:active {
  background-color: #2980b9;
  transform: translateY(4rpx);
}