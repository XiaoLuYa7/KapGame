/* ============================================
   商城页样式
   设计风格：柔和玻璃 (Soft Glass)
   支持系统级白天/黑夜模式自动切换
   ============================================ */

/* ---------- 页面容器 ---------- */
.shop-container {
  min-height: 100vh;
  background: transparent;
  padding: var(--space-xl);
  padding-bottom: 120rpx;
  position: relative;
}

/* ---------- 功能模块网格 ---------- */
.modules-grid {
  display: flex;
  flex-direction: column;
  gap: 32rpx;
  margin-top: 40rpx;
  position: relative;
  z-index: 1;
}

.module-row {
  display: flex;
  gap: 24rpx;
}

/* ---------- 模块项 - 左右布局、整体居中 ---------- */
.module-item {
  flex: 1;
  border-radius: var(--radius-lg);
  padding: 32rpx 24rpx;
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  min-height: 100rpx;
  box-sizing: border-box;
  position: relative;
  overflow: hidden;
  transition: all 0.25s ease;
  border: 2rpx solid;
}

/* 顶部装饰线 */
.module-item::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 3rpx;
  background: linear-gradient(90deg, transparent, currentColor, transparent);
  opacity: 0.6;
}

.module-item:active {
  transform: scale(0.97);
}

.module-item.full-row {
  flex: 1;
}

/* ---------- 模块图标 - 深色内陷效果 ---------- */
.module-icon {
  width: 72rpx;
  height: 72rpx;
  background: rgba(0, 0, 0, 0.35);
  border-radius: var(--radius-md);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  border: 1rpx solid rgba(255, 255, 255, 0.2);
  box-shadow: inset 0 3rpx 6rpx rgba(0, 0, 0, 0.4);
}

.module-icon text {
  font-size: 38rpx;
}

/* ---------- 模块信息 - 文字纯白不透明，有文字阴影 ---------- */
.module-info {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  text-align: left;
  min-width: 0;
}

.module-name {
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 700;
  margin-bottom: 4rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.5);
}

.module-desc {
  color: rgba(255, 255, 255, 0.85);
  font-size: 22rpx;
}

/* ---------- 设置链接 ---------- */
.settings-link {
  position: fixed;
  bottom: 40rpx;
  left: 50%;
  transform: translateX(-50%);
  color: var(--text-muted);
  font-size: 28rpx;
  font-weight: 500;
  z-index: 100;
  padding: 16rpx 32rpx;
  transition: all 0.2s ease;
}

.settings-link:active {
  color: var(--accent-primary);
  transform: translateX(-50%) scale(0.96);
}

/* ============================================
   设置弹窗
   ============================================ */
.settings-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(2, 2, 3, 0.75);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}

.modal-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--bg-card);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border-radius: var(--radius-xl) var(--radius-xl) 0 0;
  max-height: 85vh;
  overflow: hidden;
  border: 1rpx solid var(--glass-border);
  border-bottom: none;
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-xl) var(--space-xl) var(--space-lg);
  border-bottom: 1rpx solid var(--border-hairline);
  position: relative;
}

/* 拖动指示条 */
.modal-header::after {
  content: '';
  position: absolute;
  bottom: -1rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 80rpx;
  height: 6rpx;
  background: var(--border-default);
  border-radius: 3rpx;
}

.modal-title {
  color: var(--text-bright);
  font-size: 36rpx;
  font-weight: 700;
}

.modal-close {
  color: var(--text-muted);
  font-size: 44rpx;
  padding: var(--space-sm);
  transition: color 0.2s;
}

.modal-close:active {
  color: var(--accent-primary);
}

.modal-body {
  padding: var(--space-lg) var(--space-xl) 80rpx;
  max-height: 75vh;
  overflow-y: auto;
}

/* ---------- 设置分组 ---------- */
.setting-group {
  margin-bottom: var(--space-xl);
}

.group-title {
  color: var(--text-muted);
  font-size: 22rpx;
  padding: var(--space-md) 0 var(--space-sm);
  letter-spacing: 3rpx;
  text-transform: uppercase;
}

.setting-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: var(--space-lg) 0;
  border-bottom: 1rpx solid var(--border-hairline);
  transition: background 0.2s;
}

.setting-row:last-child {
  border-bottom: none;
}

.setting-row:active {
  background: var(--bg-hover);
}

.row-label {
  color: var(--text-primary);
  font-size: 30rpx;
  font-weight: 500;
}

.row-right {
  display: flex;
  align-items: center;
  gap: var(--space-sm);
}

.row-value {
  color: var(--text-muted);
  font-size: 28rpx;
}

.row-value.verified {
  color: var(--success);
}

.row-arrow {
  color: var(--border-bright);
  font-size: 34rpx;
}

/* ============================================
   模块颜色 - 明亮模式
   ============================================ */

/* 靛蓝系 - 商城 */
.module-indigo {
  background: linear-gradient(160deg, #0EA5E9 0%, #0284C7 100%);
  border-color: #38BDF8;
}
.module-indigo::before {
  background: linear-gradient(90deg, transparent, #7DD3FC, transparent);
}

/* 青色系 - 寻宝 */
.module-cyan {
  background: linear-gradient(160deg, #14B8A6 0%, #0D9488 100%);
  border-color: #2DD4BF;
}
.module-cyan::before {
  background: linear-gradient(90deg, transparent, #5EEAD4, transparent);
}

/* 金色系 - 荣耀大明星 */
.module-gold {
  background: linear-gradient(160deg, #F59E0B 0%, #D97706 100%);
  border-color: #FBBF24;
}
.module-gold::before {
  background: linear-gradient(90deg, transparent, #FDE68A, transparent);
}

/* 绿色系 - 邀请有奖 */
.module-green {
  background: linear-gradient(160deg, #10B981 0%, #059669 100%);
  border-color: #34D399;
}
.module-green::before {
  background: linear-gradient(90deg, transparent, #6EE7B7, transparent);
}

/* 紫色系 - 赏金任务 */
.module-violet {
  background: linear-gradient(160deg, #8B5CF6 0%, #7C3AED 100%);
  border-color: #A78BFA;
}
.module-violet::before {
  background: linear-gradient(90deg, transparent, #C4B5FD, transparent);
}

/* 粉色系 - 翻牌有奖 */
.module-pink {
  background: linear-gradient(160deg, #EC4899 0%, #DB2777 100%);
  border-color: #F472B6;
}
.module-pink::before {
  background: linear-gradient(90deg, transparent, #FBCFE8, transparent);
}

/* 橙色系 - 每日签到 */
.module-orange {
  background: linear-gradient(160deg, #F97316 0%, #EA580C 100%);
  border-color: #FB923C;
}
.module-orange::before {
  background: linear-gradient(90deg, transparent, #FED7AA, transparent);
}

/* 红色系 - 等级奖励 */
.module-red {
  background: linear-gradient(160deg, #EF4444 0%, #DC2626 100%);
  border-color: #F87171;
}
.module-red::before {
  background: linear-gradient(90deg, transparent, #FECACA, transparent);
}

/* ============================================
   深色模式 - 模块颜色变亮
   ============================================ */
@media (prefers-color-scheme: dark) {

  /* 靛蓝系 - 商城 */
  .module-indigo {
    background: linear-gradient(160deg, #38BDF8 0%, #0EA5E9 100%);
    border-color: #7DD3FC;
  }
  .module-indigo::before {
    background: linear-gradient(90deg, transparent, #BAE6FD, transparent);
  }

  /* 青色系 - 寻宝 */
  .module-cyan {
    background: linear-gradient(160deg, #2DD4BF 0%, #14B8A6 100%);
    border-color: #5EEAD4;
  }
  .module-cyan::before {
    background: linear-gradient(90deg, transparent, #99F6E4, transparent);
  }

  /* 金色系 - 荣耀大明星 */
  .module-gold {
    background: linear-gradient(160deg, #FBBF24 0%, #F59E0B 100%);
    border-color: #FDE68A;
  }
  .module-gold::before {
    background: linear-gradient(90deg, transparent, #FEF3C7, transparent);
  }

  /* 绿色系 - 邀请有奖 */
  .module-green {
    background: linear-gradient(160deg, #34D399 0%, #10B981 100%);
    border-color: #6EE7B7;
  }
  .module-green::before {
    background: linear-gradient(90deg, transparent, #A7F3D0, transparent);
  }

  /* 紫色系 - 赏金任务 */
  .module-violet {
    background: linear-gradient(160deg, #A78BFA 0%, #8B5CF6 100%);
    border-color: #C4B5FD;
  }
  .module-violet::before {
    background: linear-gradient(90deg, transparent, #DDD6FE, transparent);
  }

  /* 粉色系 - 翻牌有奖 */
  .module-pink {
    background: linear-gradient(160deg, #F472B6 0%, #EC4899 100%);
    border-color: #FBCFE8;
  }
  .module-pink::before {
    background: linear-gradient(90deg, transparent, #FCE7F3, transparent);
  }

  /* 橙色系 - 每日签到 */
  .module-orange {
    background: linear-gradient(160deg, #FB923C 0%, #F97316 100%);
    border-color: #FED7AA;
  }
  .module-orange::before {
    background: linear-gradient(90deg, transparent, #FFEDD5, transparent);
  }

  /* 红色系 - 等级奖励 */
  .module-red {
    background: linear-gradient(160deg, #F87171 0%, #EF4444 100%);
    border-color: #FECACA;
  }
  .module-red::before {
    background: linear-gradient(90deg, transparent, #FEE2E2, transparent);
  }
}
