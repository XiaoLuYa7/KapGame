<view class="shop-container">
  <!-- 背景图片 -->
  <image class="page-bg" src="images/bg.png" mode="aspectFill" />

  <!-- 顶部用户信息（使用公共组件） -->
  <userCard userData="{{userData}}" isLoggedIn="{{isLoggedIn}}" />

  <!-- 功能模块区域 -->
  <view class="modules-grid">
    <!-- 第一行：商城 + 寻宝 -->
    <view class="module-row">
      <view class="module-item module-indigo" bindtap="onItemTap" data-id="1">
        <view class="module-icon"><text>🛒</text></view>
        <view class="module-info">
          <text class="module-name">商城</text>
          <text class="module-desc">购买卡包</text>
        </view>
      </view>
      <view class="module-item module-cyan" bindtap="onItemTap" data-id="2">
        <view class="module-icon"><text>💎</text></view>
        <view class="module-info">
          <text class="module-name">寻宝</text>
          <text class="module-desc">神秘奖励</text>
        </view>
      </view>
    </view>

    <!-- 第二行：荣耀大明星 -->
    <view class="module-row">
      <view class="module-item module-gold full-row" bindtap="onItemTap" data-id="3">
        <view class="module-icon"><text>⭐</text></view>
        <view class="module-info">
          <text class="module-name">荣耀大明星</text>
          <text class="module-desc">荣耀排行</text>
        </view>
      </view>
    </view>

    <!-- 第三行：邀请有奖 -->
    <view class="module-row">
      <view class="module-item module-green full-row" bindtap="onItemTap" data-id="4">
        <view class="module-icon"><text>🎁</text></view>
        <view class="module-info">
          <text class="module-name">邀请有奖</text>
          <text class="module-desc">邀请好友</text>
        </view>
      </view>
    </view>

    <!-- 第四行：赏金任务 + 翻牌有奖 -->
    <view class="module-row">
      <view class="module-item module-violet" bindtap="onItemTap" data-id="5">
        <view class="module-icon"><text>⚔️</text></view>
        <view class="module-info">
          <text class="module-name">赏金任务</text>
          <text class="module-desc">完成任务</text>
        </view>
      </view>
      <view class="module-item module-pink" bindtap="onItemTap" data-id="6">
        <view class="module-icon"><text>🎴</text></view>
        <view class="module-info">
          <text class="module-name">翻牌有奖</text>
          <text class="module-desc">翻牌抽奖</text>
        </view>
      </view>
    </view>

    <!-- 第五行：每日签到 + 等级奖励 -->
    <view class="module-row">
      <view class="module-item module-orange" bindtap="onItemTap" data-id="7">
        <view class="module-icon"><text>📅</text></view>
        <view class="module-info">
          <text class="module-name">每日签到</text>
          <text class="module-desc">连续奖励</text>
        </view>
      </view>
      <view class="module-item module-red" bindtap="onItemTap" data-id="8">
        <view class="module-icon"><text>🏆</text></view>
        <view class="module-info">
          <text class="module-name">等级奖励</text>
          <text class="module-desc">等级礼包</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 设置链接 -->
  <view class="settings-link" bindtap="onSettingsTap">设置</view>

  <!-- 设置弹窗 -->
  <view class="settings-modal" wx:if="{{showSettings}}" catchtouchmove="preventTouchMove">
    <view class="modal-mask" bindtap="onCloseSettings"></view>
    <view class="modal-content">
      <view class="modal-header">
        <text class="modal-title">设置</text>
        <text class="modal-close" bindtap="onCloseSettings">✕</text>
      </view>

      <view class="modal-body">
        <!-- 账号区域 -->
        <view class="setting-group">
          <view class="group-title">账号</view>
          <view class="setting-row" bindtap="onBindPhone">
            <text class="row-label">绑定手机号</text>
            <view class="row-right">
              <text class="row-value">{{userData.phone || '未绑定'}}</text>
              <text class="row-arrow">›</text>
            </view>
          </view>
          <view class="setting-row" bindtap="onVerify">
            <text class="row-label">实名认证</text>
            <view class="row-right">
              <text class="row-value {{userData.isVerified ? 'verified' : ''}}">{{userData.isVerified ? '已认证' : '未认证'}}</text>
              <text class="row-arrow">›</text>
            </view>
          </view>
        </view>

        <!-- 声音与震动区域 -->
        <view class="setting-group">
          <view class="group-title">声音与震动</view>
          <view class="setting-row">
            <text class="row-label">音效开关</text>
            <switch checked="{{settings.soundEffectsEnabled}}" bindchange="onSoundEffectsChange" color="#5E6AD2" />
          </view>
          <view class="setting-row">
            <text class="row-label">音乐开关</text>
            <switch checked="{{settings.musicEnabled}}" bindchange="onMusicChange" color="#5E6AD2" />
          </view>
          <view class="setting-row">
            <text class="row-label">震动开关</text>
            <switch checked="{{settings.vibrationEnabled}}" bindchange="onVibrationChange" color="#5E6AD2" />
          </view>
        </view>

        <!-- 隐私设置区域 -->
        <view class="setting-group">
          <view class="group-title">隐私设置</view>
          <view class="setting-row">
            <text class="row-label">显示在线状态</text>
            <switch checked="{{settings.showOnlineStatus}}" bindchange="onShowOnlineStatusChange" color="#5E6AD2" />
          </view>
          <view class="setting-row">
            <text class="row-label">显示最后活跃</text>
            <switch checked="{{settings.showLastActiveTime}}" bindchange="onShowLastActiveTimeChange" color="#5E6AD2" />
          </view>
        </view>

        <!-- 底部链接 -->
        <view class="bottom-links">
          <text class="link" bindtap="onPrivacyPolicy">隐私政策</text>
          <text class="divider">|</text>
          <text class="link" bindtap="onUserAgreement">用户协议</text>
        </view>

        <view class="version">V{{version}}</view>
      </view>
    </view>
  </view>
</view>