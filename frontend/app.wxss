/* app.wxss */
page {
  background-color: #f5f5f5;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', sans-serif;
}

.container {
  padding: 20rpx;
}

.btn {
  background-color: #2c3e50;
  color: white;
  border-radius: 10rpx;
  padding: 20rpx;
  text-align: center;
  margin: 20rpx 0;
}

.btn:active {
  background-color: #1a252f;
}

.card {
  background-color: white;
  border-radius: 15rpx;
  padding: 30rpx;
  margin: 20rpx 0;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.1);
}

.input {
  border: 2rpx solid #ddd;
  border-radius: 10rpx;
  padding: 20rpx;
  margin: 20rpx 0;
}

.player-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx;
  margin: 10rpx 0;
  background-color: white;
  border-radius: 10rpx;
}

.hand-card {
  display: inline-block;
  width: 150rpx;
  height: 200rpx;
  background-color: #3498db;
  color: white;
  border-radius: 15rpx;
  margin: 10rpx;
  text-align: center;
  line-height: 200rpx;
  font-size: 28rpx;
}

.hand-card:active {
  background-color: #2980b9;
}