/* ============================================
   KapGame 全局主题样式
   设计风格：柔和玻璃 (Soft Glass)
   支持系统级白天/黑夜模式自动切换
   ============================================ */

/* ---------- CSS变量（设计令牌）- 明亮模式（默认）---------- */
page {
  /* 背景层次 - 雪白系 */
  --bg-void: #FAFBFC;
  --bg-deep: #F4F6F8;
  --bg-base: #FAFBFC;
  --bg-card: rgba(255, 255, 255, 0.70);
  --bg-elevated: rgba(255, 255, 255, 0.85);
  --bg-hover: rgba(255, 255, 255, 0.90);
  --bg-glass: rgba(255, 255, 255, 0.70);

  /* 天蓝色强调色系 */
  --accent-bright: #38BDF8;
  --accent-primary: #0EA5E9;
  --accent-dim: #0284C7;
  --accent-glow: rgba(14, 165, 233, 0.3);

  /* 文本层次 */
  --text-bright: #0F172A;
  --text-primary: #1E293B;
  --text-secondary: #64748B;
  --text-muted: #94A3B8;
  --text-dim: #CBD5E1;

  /* 边框与分隔 */
  --border-hairline: rgba(0, 0, 0, 0.06);
  --border-default: rgba(0, 0, 0, 0.10);
  --border-bright: rgba(0, 0, 0, 0.15);

  /* 功能色 */
  --danger: #EF4444;
  --danger-bg: rgba(239, 68, 68, 0.10);
  --success: #10B981;
  --success-bg: rgba(16, 185, 129, 0.10);
  --warning: #F59E0B;
  --warning-bg: rgba(245, 158, 11, 0.10);

  /* 玻璃效果 */
  --glass-blur: blur(12px);
  --glass-bg: rgba(255, 255, 255, 0.70);
  --glass-border: rgba(255, 255, 255, 0.50);

  /* 阴影 - 柔和投影 */
  --shadow-card: 0 4px 24px rgba(0, 0, 0, 0.06);
  --shadow-elevated: 0 8px 32px rgba(0, 0, 0, 0.08);
  --shadow-accent: 0 4px 16px var(--accent-glow);

  /* 圆角 */
  --radius-sm: 12rpx;
  --radius-md: 20rpx;
  --radius-lg: 28rpx;
  --radius-xl: 36rpx;

  /* 间距 */
  --space-xs: 8rpx;
  --space-sm: 12rpx;
  --space-md: 16rpx;
  --space-lg: 24rpx;
  --space-xl: 32rpx;
  --space-2xl: 48rpx;

  /* 过渡 */
  --transition-fast: 0.15s ease;
  --transition-normal: 0.25s ease;
  --transition-slow: 0.4s ease;
}

/* ---------- 深色模式 ---------- */
@media (prefers-color-scheme: dark) {
  page {
    /* 背景层次 - 深海蓝黑系 */
    --bg-void: #0F1419;
    --bg-deep: #111921;
    --bg-base: #0F1419;
    --bg-card: rgba(30, 41, 59, 0.60);
    --bg-elevated: rgba(30, 41, 59, 0.80);
    --bg-hover: rgba(30, 41, 59, 0.90);
    --bg-glass: rgba(30, 41, 59, 0.60);

    /* 冰蓝色强调色系 */
    --accent-bright: #7DD3FC;
    --accent-primary: #38BDF8;
    --accent-dim: #0EA5E9;
    --accent-glow: rgba(56, 189, 248, 0.35);

    /* 文本层次 */
    --text-bright: #F1F5F9;
    --text-primary: #E2E8F0;
    --text-secondary: #94A3B8;
    --text-muted: #64748B;
    --text-dim: #475569;

    /* 边框与分隔 */
    --border-hairline: rgba(255, 255, 255, 0.06);
    --border-default: rgba(255, 255, 255, 0.10);
    --border-bright: rgba(255, 255, 255, 0.15);

    /* 功能色 */
    --danger: #F87171;
    --danger-bg: rgba(248, 113, 113, 0.15);
    --success: #34D399;
    --success-bg: rgba(52, 211, 153, 0.15);
    --warning: #FBBF24;
    --warning-bg: rgba(251, 191, 36, 0.15);

    /* 玻璃效果 */
    --glass-blur: blur(12px);
    --glass-bg: rgba(30, 41, 59, 0.60);
    --glass-border: rgba(255, 255, 255, 0.08);

    /* 阴影 - 深色模式更明显 */
    --shadow-card: 0 4px 24px rgba(0, 0, 0, 0.30);
    --shadow-elevated: 0 8px 32px rgba(0, 0, 0, 0.40);
    --shadow-accent: 0 4px 16px var(--accent-glow);
  }
}

/* ---------- 全局重置 ---------- */
page {
  background: var(--bg-base);
  font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'PingFang SC', sans-serif;
  color: var(--text-primary);
  font-size: 28rpx;
  line-height: 1.5;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

.container {
  padding: var(--space-lg);
}

/* ---------- 玻璃卡片 ---------- */
.glass-card {
  background: var(--glass-bg);
  backdrop-filter: var(--glass-blur);
  -webkit-backdrop-filter: var(--glass-blur);
  border: 1rpx solid var(--glass-border);
  border-radius: var(--radius-md);
  padding: var(--space-xl);
  box-shadow: var(--shadow-card);
  transition: box-shadow var(--transition-normal), background var(--transition-normal);
}

.glass-card:hover {
  box-shadow: var(--shadow-elevated);
}

.glass-card:active {
  transform: scale(0.98);
  transition: transform var(--transition-fast);
}

/* ---------- 通用卡片 ---------- */
.card {
  background: var(--bg-card);
  border: 1rpx solid var(--border-default);
  border-radius: var(--radius-md);
  padding: var(--space-lg);
  box-shadow: var(--shadow-card);
  transition: box-shadow var(--transition-normal), border-color var(--transition-normal);
}

.card:hover {
  border-color: var(--border-bright);
  box-shadow: var(--shadow-elevated);
}

.card-elevated {
  background: var(--bg-elevated);
  box-shadow: var(--shadow-elevated);
}

/* ---------- 按钮系统 ---------- */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-md) var(--space-xl);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  font-weight: 500;
  border: none;
  cursor: pointer;
  transition: all var(--transition-fast);
  -webkit-tap-highlight-color: transparent;
}

.btn:active {
  transform: scale(0.96);
}

.btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
  transform: none;
}

/* 主按钮 - 天蓝色 */
.btn-primary {
  background: linear-gradient(135deg, var(--accent-primary) 0%, var(--accent-dim) 100%);
  color: #FFFFFF;
  box-shadow: var(--shadow-accent);
}

.btn-primary:hover {
  background: linear-gradient(135deg, var(--accent-bright) 0%, var(--accent-primary) 100%);
  box-shadow: var(--shadow-elevated);
}

/* 次要按钮 */
.btn-secondary {
  background: var(--bg-elevated);
  color: var(--text-primary);
  border: 1rpx solid var(--border-default);
}

.btn-secondary:hover {
  background: var(--bg-hover);
  border-color: var(--border-bright);
}

.btn-secondary:active {
  background: var(--bg-card);
}

/* 危险按钮 */
.btn-danger {
  background: var(--danger);
  color: #FFFFFF;
}

.btn-danger:hover {
  background: #DC2626;
}

/* 幽灵按钮 */
.btn-ghost {
  background: transparent;
  color: var(--text-primary);
  border: 1rpx solid var(--border-default);
}

.btn-ghost:hover {
  background: var(--bg-card);
  border-color: var(--border-bright);
}

/* 按钮尺寸变体 */
.btn-sm {
  padding: var(--space-sm) var(--space-lg);
  font-size: 24rpx;
}

.btn-lg {
  padding: var(--space-lg) var(--space-2xl);
  font-size: 32rpx;
}

/* ---------- 输入框 ---------- */
.input {
  width: 100%;
  padding: var(--space-md) var(--space-lg);
  background: var(--bg-card);
  border: 1rpx solid var(--border-default);
  border-radius: var(--radius-md);
  font-size: 28rpx;
  color: var(--text-primary);
  transition: all var(--transition-fast);
  box-sizing: border-box;
}

.input::placeholder {
  color: var(--text-muted);
}

.input:focus {
  outline: none;
  border-color: var(--accent-primary);
  box-shadow: 0 0 0 3rpx var(--accent-glow);
  background: var(--bg-elevated);
}

.input:disabled {
  opacity: 0.6;
  cursor: not-allowed;
  background: var(--bg-glass);
}

/* 输入框带图标 */
.input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
}

.input-wrapper .input {
  padding-left: 72rpx;
}

.input-icon {
  position: absolute;
  left: var(--space-lg);
  color: var(--text-muted);
  font-size: 32rpx;
  pointer-events: none;
}

/* ---------- 分割线 ---------- */
.divider {
  width: 100%;
  height: 1rpx;
  background: var(--border-default);
  margin: var(--space-lg) 0;
}

.divider-vertical {
  width: 1rpx;
  height: 100%;
  background: var(--border-default);
  margin: 0 var(--space-lg);
}

.divider-light {
  height: 1rpx;
  background: var(--border-hairline);
}

.divider-accent {
  height: 2rpx;
  background: linear-gradient(90deg, var(--accent-primary), var(--accent-bright));
  width: 120rpx;
  margin: var(--space-md) 0;
}

/* ---------- 列表项 ---------- */
.list-item {
  display: flex;
  align-items: center;
  padding: var(--space-lg);
  background: var(--bg-card);
  border-radius: var(--radius-md);
  transition: all var(--transition-fast);
  min-height: 88rpx;
  box-sizing: border-box;
}

.list-item:hover {
  background: var(--bg-hover);
}

.list-item:active {
  background: var(--bg-elevated);
  transform: scale(0.99);
}

.list-item + .list-item {
  margin-top: var(--space-sm);
}

.list-item-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: var(--space-xs);
}

.list-item-title {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
}

.list-item-subtitle {
  font-size: 24rpx;
  color: var(--text-secondary);
}

.list-item-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-lg);
  background: var(--bg-elevated);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: var(--space-lg);
  font-size: 36rpx;
}

.list-item-arrow {
  color: var(--text-muted);
  font-size: 24rpx;
  margin-left: var(--space-md);
}

/* ---------- 头像 ---------- */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--accent-primary), var(--accent-dim));
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 600;
  overflow: hidden;
  flex-shrink: 0;
}

.avatar image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 头像尺寸变体 */
.avatar-sm {
  width: 56rpx;
  height: 56rpx;
  font-size: 24rpx;
}

.avatar-lg {
  width: 112rpx;
  height: 112rpx;
  font-size: 44rpx;
}

.avatar-xl {
  width: 144rpx;
  height: 144rpx;
  font-size: 56rpx;
}

/* 头像带边框 */
.avatar-bordered {
  border: 3rpx solid var(--accent-primary);
  box-shadow: 0 0 12rpx var(--accent-glow);
}

/* ---------- 辅助工具类 ---------- */

/* Flex工具 */
.flex { display: flex; }
.flex-col { display: flex; flex-direction: column; }
.flex-center { display: flex; align-items: center; justify-content: center; }
.flex-between { display: flex; align-items: center; justify-content: space-between; }
.flex-1 { flex: 1; }
.gap-sm { gap: var(--space-sm); }
.gap-md { gap: var(--space-md); }
.gap-lg { gap: var(--space-lg); }

/* 文本工具 */
.text-primary { color: var(--text-primary); }
.text-secondary { color: var(--text-secondary); }
.text-muted { color: var(--text-muted); }
.text-accent { color: var(--accent-primary); }
.text-danger { color: var(--danger); }
.text-success { color: var(--success); }
.text-center { text-align: center; }
.text-bold { font-weight: 600; }

/* 间距工具 */
.mt-sm { margin-top: var(--space-sm); }
.mt-md { margin-top: var(--space-md); }
.mt-lg { margin-top: var(--space-lg); }
.mb-sm { margin-bottom: var(--space-sm); }
.mb-md { margin-bottom: var(--space-md); }
.mb-lg { margin-bottom: var(--space-lg); }
.p-sm { padding: var(--space-sm); }
.p-md { padding: var(--space-md); }
.p-lg { padding: var(--space-lg); }

/* 圆角工具 */
.radius-sm { border-radius: var(--radius-sm); }
.radius-md { border-radius: var(--radius-md); }
.radius-lg { border-radius: var(--radius-lg); }
.radius-full { border-radius: 50%; }

/* 背景工具 */
.bg-card { background: var(--bg-card); }
.bg-elevated { background: var(--bg-elevated); }
.bg-glass { background: var(--bg-glass); backdrop-filter: var(--glass-blur); }

/* 阴影工具 */
.shadow-card { box-shadow: var(--shadow-card); }
.shadow-elevated { box-shadow: var(--shadow-elevated); }

/* 安全区域适配 */
.safe-area-top {
  padding-top: constant(safe-area-inset-top);
  padding-top: env(safe-area-inset-top);
}

.safe-area-bottom {
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
}
