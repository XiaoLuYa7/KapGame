<view class="user-section" bindtap="onTap">
  <view class="user-avatar">
    <image wx:if="{{userData.avatarUrl && userData.avatarUrl.startsWith('http')}}" src="{{userData.avatarUrl}}" mode="aspectFill"></image>
    <text wx:else class="avatar-emoji">🎭</text>
    <view class="avatar-badge" wx:if="{{isLoggedIn && userData.level > 0}}">
      <text class="badge-text">Lv.{{userData.level}}</text>
    </view>
  </view>
  <view class="user-info">
    <view class="username">{{isLoggedIn ? userData.username : '点击登录'}}</view>
    <view class="rank-info">
      <text class="rank-label">段位</text>
      <view class="rank-bar">
        <text class="rank-value">{{isLoggedIn ? userData.rank : '未登录'}}</text>
      </view>
    </view>
    <view class="resources" wx:if="{{isLoggedIn}}">
      <view class="resource-item">
        <text class="resource-icon">💎</text>
        <text class="resource-value">{{userData.diamond}}</text>
      </view>
      <view class="resource-item">
        <text class="resource-icon">🪙</text>
        <text class="resource-value">{{userData.gold}}</text>
      </view>
    </view>
  </view>
  <view class="login-prompt" wx:if="{{!isLoggedIn}}">
    <text class="login-text">登录</text>
    <text class="login-arrow">›</text>
  </view>
</view>